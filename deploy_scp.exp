#!/usr/bin/expect -f
set port [lindex $argv 0]
set user_host [lindex $argv 1]
set password [lindex $argv 2]
set local_file [lindex $argv 3]
set remote_file [lindex $argv 4]

set timeout 60
spawn scp -P $port $local_file $user_host:$remote_file
expect {
    "yes/no" {
        send "yes\r"
        exp_continue
    }
    "password:" {
        send "$password\r"
    }
}
expect eof
